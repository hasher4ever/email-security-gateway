# ─── Domain ──────────────────────────────────────────────────────────────
# The corp domain whose mail flows through this gateway
CORP_DOMAIN=example.com
GATEWAY_HOSTNAME=mail.example.com

# Comma-separated trusted domains for dnstwist baseline (load boards, brokers, our own)
TRUSTED_DOMAINS=tms360.io,dat.com,truckstop.com,123loadboard.com

# ─── Postgres ────────────────────────────────────────────────────────────
POSTGRES_USER=esg
POSTGRES_PASSWORD=change-me
POSTGRES_DB=esg
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Reputation feeds ────────────────────────────────────────────────────
# Google Safe Browsing — https://developers.google.com/safe-browsing/v4/get-started
GSB_API_KEY=

# PhishTank requires no key but recommends one — https://phishtank.org/api_register.php
PHISHTANK_APP_KEY=

# OpenPhish — community feed is free (no key); commercial feed needs a key
OPENPHISH_API_KEY=

# ─── Detonator ───────────────────────────────────────────────────────────
DETONATOR_URL=http://detonator:7000
DETONATOR_TIMEOUT_SEC=30
DETONATOR_USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0 Safari/537.36"
CACHE_TTL_SEC=86400

# ─── Mode ────────────────────────────────────────────────────────────────
# shadow = log verdicts but never block (Phase 1 default — tune for 2 weeks)
# enforce = quarantine high-score, mark spam mid-score
GATEWAY_MODE=shadow

# Shadow-mode quarantine target (BCC of suspicious mail)
SHADOW_BCC=quarantine@example.com

# ─── Outbound (sim only) ─────────────────────────────────────────────────
# Use a separate ESP credential for Gophish so simulation traffic doesn't
# mingle with the inbound gateway's loop-detection paths.
GOPHISH_SMTP_HOST=
GOPHISH_SMTP_PORT=587
GOPHISH_SMTP_USER=
GOPHISH_SMTP_PASS=
GOPHISH_FROM_DOMAIN=tms360-portal.io
